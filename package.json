{
  "name": "custom-ide",
  "version": "1.0.0",
  "description": "IDE с собственной языковой моделью через LM Studio",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "tsc && electron .",
    "pack": "npm run build && electron-packager . Sirius-IDE --platform=win32 --arch=x64 --out=release --overwrite",
    "dist": "npm run build && electron-builder --win nsis portable",
    "postinstall": "node scripts/patch-node-pty.js && electron-rebuild -f -w node-pty"
  },
  "keywords": [
    "ide",
    "electron",
    "monaco",
    "lm-studio"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.10.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.1.2",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.3.0"
  },
  "build": {
    "appId": "com.sirius.ide",
    "productName": "Sirius IDE",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "renderer/**/*",
      "node_modules/**/*",
      "package.json",
      "icon.ico"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "fs-extra": "^11.2.0",
    "monaco-editor": "^0.45.0",
    "node-pty": "^1.0.0",
    "simple-git": "^3.33.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  }
}
